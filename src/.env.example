COHERE_API_KEY=""

 # "gpt-5-nano"  "text-embedding-3-small"
GENERATION_MODEL_ID_LITERAL = ["gpt-5-nano", "gemma2:9b-instruct-q5_0"]
GENERATION_MODEL_ID="gemma2:9b-instruct-q5_0"
EMBEDDING_MODEL_ID="qwen3-embedding:0.6b"
